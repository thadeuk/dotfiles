font=JetBrains Mono Nerd Font 11

background-color=#0B0C16
text-color=#ddf7ff
border-color=#82FB9C
progress-color=#82FB9C

width=360
height=120
margin=20
padding=12
border-size=2
border-radius=12

anchor=top-right
layer=overlay

default-timeout=6000
