#!/usr/bin/env bash
# Sync Omarchy themes from the manifest at ~/.config/omarchy/themes.manifest.
#
# Manifest entries:
#   <name>                 → copy from cached basecamp/omarchy clone (themes/<name>)
#   <name> basecamp        → same, explicit
#   <name> <git-url>       → clone (and `git pull --ff-only` thereafter)
#
# basecamp/omarchy is cached at ~/.cache/omarchy-upstream so the script can
# re-copy themes without re-downloading. Each run pulls the cache to update.

set -euo pipefail

THEMES_DIR="$HOME/.config/omarchy/themes"
MANIFEST="$HOME/.config/omarchy/themes.manifest"
CACHE="$HOME/.cache/omarchy-upstream"
UPSTREAM_URL="https://github.com/basecamp/omarchy"

[[ -f "$MANIFEST" ]] || { echo "manifest not found: $MANIFEST" >&2; exit 1; }
mkdir -p "$THEMES_DIR"

# Does any manifest entry need the upstream cache?
need_upstream=0
while IFS=' ' read -r name src _rest; do
  [[ -z "${name// }" || "$name" == \#* ]] && continue
  if [[ -z "${src:-}" || "$src" == "basecamp" ]]; then
    need_upstream=1
    break
  fi
done < "$MANIFEST"

if (( need_upstream )); then
  if [[ -d "$CACHE/.git" ]]; then
    echo "[cache] pulling basecamp/omarchy"
    git -C "$CACHE" pull --ff-only --quiet
  else
    echo "[cache] cloning basecamp/omarchy → $CACHE"
    git clone --depth=1 --quiet "$UPSTREAM_URL" "$CACHE"
  fi
fi

cloned=0; copied=0; pulled=0; skipped=0; missing=0

while IFS=' ' read -r name src _rest; do
  [[ -z "${name// }" || "$name" == \#* ]] && continue
  target="$THEMES_DIR/$name"

  # Upstream basecamp/omarchy theme
  if [[ -z "${src:-}" || "$src" == "basecamp" ]]; then
    upstream_dir="$CACHE/themes/$name"
    if [[ ! -d "$upstream_dir" ]]; then
      echo "[error] $name: not in basecamp/omarchy/themes/" >&2
      ((++missing))
      continue
    fi
    rm -rf "$target"
    cp -r "$upstream_dir" "$target"
    echo "[copy]  $name (basecamp)"
    ((++copied))
    continue
  fi

  # Standalone-repo theme
  url="$src"
  if [[ -d "$target/.git" ]]; then
    echo "[pull]  $name"
    if git -C "$target" pull --ff-only --quiet; then ((++pulled)); fi
  elif [[ -d "$target" ]]; then
    echo "[skip]  $name (exists, not a clone)"
    ((++skipped))
  else
    echo "[clone] $name ← $url"
    if git clone --depth=1 --quiet "$url" "$target"; then ((++cloned)); fi
  fi
done < "$MANIFEST"

printf '\nsummary: cloned=%d  copied=%d  pulled=%d  skipped=%d  missing-upstream=%d\n' \
  "$cloned" "$copied" "$pulled" "$skipped" "$missing"
