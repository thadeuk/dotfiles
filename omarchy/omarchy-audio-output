#!/usr/bin/env bash
# Wofi menu to switch the default PipeWire/PulseAudio sink.
# Also migrates currently-playing streams to the new sink.

set -euo pipefail

current=$(pactl get-default-sink)

# Build a TAB-separated table: "Description [●]\tSinkName"
menu=$(pactl list sinks | awk -v current="$current" '
  /^[[:space:]]*Name:/        { name = $2 }
  /^[[:space:]]*Description:/ {
    sub(/^[[:space:]]*Description: /, "")
    marker = (name == current) ? " ●" : ""
    print $0 marker "\t" name
  }
')

label=$(printf '%s\n' "$menu" | cut -f1 | wofi --dmenu --prompt "Audio output" -i)
[[ -z "$label" ]] && exit 0

sink=$(printf '%s\n' "$menu" | awk -v l="$label" -F'\t' '$1 == l { print $2; exit }')
[[ -z "$sink" ]] && exit 0

pactl set-default-sink "$sink"

# Move existing streams to the new sink so playback follows.
pactl list short sink-inputs | awk '{print $1}' | while read -r id; do
  pactl move-sink-input "$id" "$sink" 2>/dev/null || true
done

desc=${label% ●}
notify-send -a Audio "Output switched" "$desc"
